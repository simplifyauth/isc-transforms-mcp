# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real credentials.

# ── Phase 2 (Enterprise) — ISC Tenant credentials ─────────────────────────
# Required for isc_transforms_list, isc_transforms_get,
# isc_transforms_upsert, isc_transforms_findReferences

# Option A: Tenant name (expands to https://{tenant}.api.identitynow.com)
ISC_TENANT=your-tenant-name

# Option B: Explicit base URL (use instead of ISC_TENANT if needed)
# ISC_API_BASE_URL=https://your-tenant.api.identitynow.com

# Auth — PAT (recommended)
ISC_PAT_CLIENT_ID=your-pat-client-id
ISC_PAT_CLIENT_SECRET=your-pat-client-secret

# Auth — pre-minted bearer token (alternative to PAT)
# ISC_ACCESS_TOKEN=eyJhbGciOi...

# ── Enterprise license ─────────────────────────────────────────────────────
# Required for Phase 2 tools. Enterprise plan coming soon.
# ISC_MCP_LICENSE_KEY=ISC-XXXX-XXXX-XXXX-XXXX

# ── Behaviour ──────────────────────────────────────────────────────────────
ISC_MCP_MODE=readonly        # set to 'write' to allow isc_transforms_upsert to apply changes
ISC_MCP_DEBUG=false
ISC_TIMEOUT_MS=30000
